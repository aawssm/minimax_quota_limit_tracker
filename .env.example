# Provider API Keys (prefix-based routing)
# -------------------------------------------
# zai_*   -> Z.ai API         (api.z.ai)
# minig_* -> Minimax Global   (api.minimax.io)
# minic_* -> Minimax China    (api.minimaxi.com)
#
# You can add multiple keys per provider:
#   minig_KEY=sk-cp-...
#   minig_KEY2=sk-cp-...
#   zai_a=your_zai_api_key_here
#   zai_b=another_key...

# Legacy support: if no minig_*/minic_* keys are set,
# API_KEY will be used with API_BASE (default: api.minimaxi.com)
# API_KEY=your_key_here

# Optional: Override base URL for legacy API_KEY only
# API_BASE=https://api.minimaxi.com

# Optional: Port (defaults to 3000)
# PORT=3000
